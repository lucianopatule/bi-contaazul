<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ContaAzul BI — PED Intelligence</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{
  --brand-base:#2E0551;
  --bg:#1A0230;
  --bg-2:#240440;
  --panel:#2E0551;
  --panel2:#3A076A;
  --card:#4A0A85;
  --border:rgba(220,200,255,.18);
  --line:rgba(220,200,255,.10);
  --text:#F2EDFF;
  --muted:#C9B8EA;
  --dim:#8E7CB8;
  --gold:#E5B943;
  --pink:#EC2E9A;
  --magenta:#D81B8E;
  --purple:#9333EA;    --purple-2:#A855F7;
  --blue:#3B82F6;      --blue-2:#60A5FA;
  --cyan:#06B6D4;      --cyan-2:#22D3EE;
  --teal:#14B8A6;
  --green:#10B981;     --green-2:#22C55E;
  --yellow:#F59E0B;    --amber:#FBBF24;
  --red:#EF4444;       --red-2:#F87171;
  --grad-brand: linear-gradient(135deg,#EC2E9A 0%,#9333EA 35%,#3B82F6 70%,#06B6D4 100%);
  --grad-pink-purple: linear-gradient(135deg,#EC2E9A,#9333EA);
  --grad-purple-blue: linear-gradient(135deg,#9333EA,#3B82F6);
  --grad-blue-cyan:   linear-gradient(135deg,#3B82F6,#06B6D4);
  --grad-green:       linear-gradient(135deg,#10B981,#22C55E);
  --grad-red:         linear-gradient(135deg,#EF4444,#F59E0B);
  --shadow: 0 10px 40px rgba(147,51,234,.15), 0 2px 8px rgba(0,0,0,.35);
  --radius: 14px;
  --radius-sm: 8px;
  --font: 'Inter','Segoe UI',system-ui,-apple-system,Arial,sans-serif;
  --font-mono: 'JetBrains Mono','Consolas',monospace;
}
*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--bg);color:var(--text);font-family:var(--font);font-size:13px;line-height:1.45}
body::before{content:"";position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(1200px 600px at -10% -10%, rgba(236,46,154,.10), transparent 60%),
    radial-gradient(900px 600px at 110% 0%, rgba(6,182,212,.08), transparent 60%),
    radial-gradient(900px 600px at 50% 120%, rgba(229,185,67,.08), transparent 60%),
    radial-gradient(1000px 700px at 50% 50%, rgba(46,5,81,.4), transparent 70%);
}
.app{display:grid;grid-template-columns:248px 1fr;min-height:100vh;position:relative;z-index:1}
.hidden{display:none !important}
.sidebar{background:linear-gradient(180deg,rgba(15,9,42,.85),rgba(10,8,24,.85));backdrop-filter:blur(18px);border-right:1px solid var(--border);padding:20px 14px;position:sticky;top:0;height:100vh;overflow-y:auto}
.brand{display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:22px;padding:8px 4px 12px;border-bottom:1px solid var(--line)}
.brand-logo{width:120px;height:120px;border-radius:18px;display:flex;align-items:center;justify-content:center;background:var(--grad-brand);box-shadow:0 8px 24px rgba(0,0,0,.45),0 0 0 1.5px rgba(255,255,255,.6);font-weight:800;font-size:20px;color:#fff;letter-spacing:1.5px;text-align:center;line-height:1.1}
.brand-title{font-size:13px;font-weight:800;color:var(--text);letter-spacing:1px;text-align:center}
.brand-sub{color:var(--gold);font-size:10px;letter-spacing:1.4px;font-weight:800;text-transform:uppercase;text-align:center;margin-top:-2px}
.nav-item{display:flex;align-items:center;gap:11px;padding:10px 12px;border-radius:10px;cursor:pointer;color:var(--muted);font-weight:500;margin-bottom:4px;position:relative;transition:all .15s ease}
.nav-item:hover{background:rgba(147,51,234,.12);color:var(--text);transform:translateX(2px)}
.nav-item.active{background:linear-gradient(90deg,rgba(236,46,154,.18),rgba(147,51,234,.12) 40%,transparent);color:#fff}
.nav-item.active::before{content:"";position:absolute;left:0;top:8px;bottom:8px;width:3px;border-radius:2px;background:var(--grad-brand)}
.nav-ico{width:18px;height:18px;flex:0 0 18px;opacity:.9}
.nav-title{font-size:10.5px;color:var(--dim);text-transform:uppercase;letter-spacing:1px;margin:16px 8px 6px;font-weight:700}
.main{display:flex;flex-direction:column;min-width:0}
.topbar{background:rgba(21,16,58,.75);backdrop-filter:blur(18px) saturate(150%);border-bottom:1px solid var(--border);padding:14px 22px;display:flex;gap:18px;flex-wrap:wrap;align-items:end;position:sticky;top:0;z-index:10;box-shadow:0 4px 20px rgba(0,0,0,.25)}
.filter-group{display:flex;flex-direction:column;gap:5px;min-width:150px}
.filter-group label{font-size:10.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;font-weight:700}
.select-box{background:rgba(28,21,72,.7);border:1px solid var(--border);color:var(--text);padding:7px 11px;border-radius:8px;font-size:12px;cursor:pointer;min-height:34px;transition:all .15s ease;min-width:220px}
.select-box:hover{border-color:var(--purple-2);background:rgba(168,85,247,.1)}
.btn-sync{background:var(--grad-purple-blue);color:#fff;border:0;padding:8px 14px;border-radius:8px;font-weight:700;cursor:pointer;font-size:12px;min-height:34px;transition:all .15s}
.btn-sync:hover{filter:brightness(1.15);transform:translateY(-1px)}
.btn-sync:disabled{opacity:.5;cursor:wait}
.sync-status{font-size:11px;color:var(--muted)}
.sync-status.ok{color:var(--green-2)}
.sync-status.err{color:var(--red-2)}
.content{padding:24px;display:flex;flex-direction:column;gap:20px}
.page-title{display:flex;justify-content:space-between;align-items:flex-end;gap:16px;margin-bottom:8px}
.page-title h1{margin:0;font-size:22px;font-weight:800;letter-spacing:-.3px;background:var(--grad-brand);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.page-title .subtitle{color:var(--muted);font-size:12px;margin-top:3px}
.grid-kpi{display:grid;grid-template-columns:repeat(auto-fit, minmax(180px, 1fr));gap:14px}
.kpi{background:linear-gradient(135deg,rgba(74,10,133,.6),rgba(46,5,81,.6));border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;position:relative;overflow:hidden;box-shadow:var(--shadow);transition:all .18s}
.kpi:hover{transform:translateY(-2px);border-color:var(--purple-2);box-shadow:0 14px 44px rgba(147,51,234,.22)}
.kpi::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad-brand)}
.kpi.green::before{background:var(--grad-green)}
.kpi.red::before{background:var(--grad-red)}
.kpi.blue::before{background:var(--grad-blue-cyan)}
.kpi.gold::before{background:linear-gradient(135deg,#F59E0B,#E5B943)}
.kpi-label{font-size:10.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;font-weight:700;margin-bottom:6px}
.kpi-value{font-size:22px;font-weight:800;color:var(--text);font-variant-numeric:tabular-nums;letter-spacing:-.5px}
.kpi-sub{font-size:11px;color:var(--dim);margin-top:3px;font-weight:500}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.grid-3{display:grid;grid-template-columns:repeat(3, 1fr);gap:16px}
@media (max-width: 1100px){ .grid-2, .grid-3{grid-template-columns:1fr} }
.panel{background:linear-gradient(135deg,rgba(58,7,106,.6),rgba(46,5,81,.5));border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;box-shadow:var(--shadow)}
.panel h3{margin:0 0 6px;font-size:13px;font-weight:700;color:var(--text);letter-spacing:.2px}
.panel .sub{color:var(--muted);font-size:11px;margin-bottom:10px}
.chart-wrap{position:relative;height:280px}
.chart-wrap.tall{height:360px}
.chart-wrap.short{height:200px}
table.bi{width:100%;border-collapse:collapse;font-size:12px;font-variant-numeric:tabular-nums}
table.bi th, table.bi td{padding:8px 10px;border-bottom:1px solid var(--line);text-align:left}
table.bi th{color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.6px;font-weight:700;background:rgba(28,21,72,.3);position:sticky;top:0}
table.bi tbody tr:hover{background:rgba(147,51,234,.08)}
.tbl-wrap{max-height:460px;overflow:auto;border-radius:var(--radius-sm);border:1px solid var(--line)}
.num{text-align:right;font-variant-numeric:tabular-nums}
.pill{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700;letter-spacing:.4px}
.pill.rec{background:rgba(16,185,129,.2);color:#4ade80}
.pill.pag{background:rgba(239,68,68,.18);color:#fca5a5}
.pill.liq{background:rgba(34,211,238,.18);color:#67e8f9}
.pill.aberto{background:rgba(168,85,247,.18);color:#c4b5fd}
.pill.vencido{background:rgba(239,68,68,.22);color:#fca5a5}
.pill.avencer{background:rgba(245,158,11,.18);color:#fcd34d}
.empty-state{text-align:center;padding:40px 20px;color:var(--muted)}
.empty-state h4{margin:0 0 6px;color:var(--text);font-size:15px}
.loader{display:inline-block;width:16px;height:16px;border:2.5px solid rgba(168,85,247,.3);border-top-color:var(--purple-2);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-logo">PED</div>
      <div class="brand-title">PED Intelligence</div>
      <div class="brand-sub">BI ContaAzul</div>
    </div>
    <div class="nav-title">Análise</div>
    <div class="nav-item active" data-page="resumo">
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
      <span>Resumo Executivo</span>
    </div>
    <div class="nav-item" data-page="fluxo">
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 14l4-6 4 4 5-7"/></svg>
      <span>Fluxo de Caixa</span>
    </div>
    <div class="nav-item" data-page="receber">
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      <span>Contas a Receber</span>
    </div>
    <div class="nav-item" data-page="pagar">
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7v10l10 5 10-5V7l-10-5z"/><path d="M12 22V12"/></svg>
      <span>Contas a Pagar</span>
    </div>
    <div class="nav-item" data-page="dre">
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20V10M10 20V4M16 20v-8M22 20H2"/></svg>
      <span>DRE por Categoria</span>
    </div>
    <div class="nav-item" data-page="vendas">
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
      <span>Vendas</span>
    </div>
    <div class="nav-title">Fontes</div>
    <div class="nav-item" onclick="window.open('/docs','_blank')">
      <svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <span>API Docs</span>
    </div>
  </aside>
  <main class="main">
    <div class="topbar">
      <div class="filter-group">
        <label>Empresa</label>
        <select class="select-box" id="empresa-select"><option value="">Carregando...</option></select>
      </div>
      <div class="filter-group">
        <label>Ações</label>
        <button class="btn-sync" id="btn-sync">Sincronizar dados</button>
      </div>
      <div class="filter-group">
        <label>Status Sync</label>
        <div class="sync-status" id="sync-status">—</div>
      </div>
      <div class="filter-group">
        <label>Último sync</label>
        <div class="sync-status" id="last-sync">—</div>
      </div>
    </div>
    <div class="content">
      <section id="page-resumo">
        <div class="page-title"><div><h1>Resumo Executivo</h1><div class="subtitle">Visão geral financeira da empresa selecionada</div></div></div>
        <div class="grid-kpi" id="kpi-cards"></div>
        <div class="grid-2">
          <div class="panel"><h3>Aging de Recebíveis</h3><div class="sub">Distribuição de valores a receber por faixa de vencimento</div><div class="chart-wrap"><canvas id="ch-aging-receber"></canvas></div></div>
          <div class="panel"><h3>Aging de Pagáveis</h3><div class="sub">Distribuição de valores a pagar por faixa de vencimento</div><div class="chart-wrap"><canvas id="ch-aging-pagar"></canvas></div></div>
        </div>
        <div class="panel"><h3>Top 10 Categorias de Receita</h3><div class="sub">Ranking das categorias que mais movimentam financeiramente</div><div class="chart-wrap tall"><canvas id="ch-top-categorias"></canvas></div></div>
      </section>
      <section id="page-fluxo" class="hidden">
        <div class="page-title"><div><h1>Fluxo de Caixa</h1><div class="subtitle">Entradas × Saídas (previstas e realizadas) no tempo</div></div></div>
        <div class="panel"><h3>Evolução temporal</h3><div class="sub">Linhas sólidas = realizado; pontilhadas = previsto</div><div class="chart-wrap tall"><canvas id="ch-fluxo"></canvas></div></div>
        <div class="grid-2">
          <div class="panel"><h3>Saldo acumulado</h3><div class="sub">Entrada realizada - Saída realizada, cumulativo</div><div class="chart-wrap"><canvas id="ch-saldo-acum"></canvas></div></div>
          <div class="panel"><h3>Totais do período</h3><div class="tbl-wrap"><table class="bi" id="tbl-fluxo-totais"><thead><tr><th>Indicador</th><th class="num">Valor</th></tr></thead><tbody></tbody></table></div></div>
        </div>
