      <section id="page-receber" class="hidden">
        <div class="page-title"><div><h1>Contas a Receber</h1><div class="subtitle">Parcelas com tipo RECEBER — detalhado</div></div></div>
        <div class="panel"><h3>Lista de Recebíveis</h3><div class="sub" id="sub-receber">—</div><div class="tbl-wrap" style="max-height:560px"><table class="bi" id="tbl-receber"><thead><tr><th>Cliente</th><th>Descrição</th><th>Vencimento</th><th>Pagamento</th><th class="num">Previsto</th><th class="num">Pago</th><th class="num">Saldo</th><th>Situação</th><th class="num">Atraso</th></tr></thead><tbody></tbody></table></div></div>
      </section>
      <section id="page-pagar" class="hidden">
        <div class="page-title"><div><h1>Contas a Pagar</h1><div class="subtitle">Parcelas com tipo PAGAR — detalhado</div></div></div>
        <div class="panel"><h3>Lista de Pagáveis</h3><div class="sub" id="sub-pagar">—</div><div class="tbl-wrap" style="max-height:560px"><table class="bi" id="tbl-pagar"><thead><tr><th>Fornecedor</th><th>Descrição</th><th>Vencimento</th><th>Pagamento</th><th class="num">Previsto</th><th class="num">Pago</th><th class="num">Saldo</th><th>Situação</th><th class="num">Atraso</th></tr></thead><tbody></tbody></table></div></div>
      </section>
      <section id="page-dre" class="hidden">
        <div class="page-title"><div><h1>DRE por Categoria</h1><div class="subtitle">Receitas e despesas agrupadas por categoria e mês</div></div></div>
        <div class="grid-2">
          <div class="panel"><h3>Receitas por Categoria (Top 10)</h3><div class="chart-wrap tall"><canvas id="ch-dre-receitas"></canvas></div></div>
          <div class="panel"><h3>Despesas por Categoria (Top 10)</h3><div class="chart-wrap tall"><canvas id="ch-dre-despesas"></canvas></div></div>
        </div>
