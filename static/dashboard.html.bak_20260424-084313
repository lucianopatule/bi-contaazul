        <div class="panel"><h3>Lista de Vendas</h3><div class="tbl-wrap" style="max-height:560px"><table class="bi" id="tbl-vendas"><thead><tr><th>Nº</th><th>Data</th><th>Cliente</th><th class="num">Valor</th><th>Status</th><th>Tipo</th></tr></thead><tbody></tbody></table></div></div>
      </section>
    </div>
  </main>
</div>

<script>
const API_BASE = window.location.origin.includes('localhost') || window.location.origin.includes('127.0.0.1')
  ? window.location.origin : 'http://localhost:8000';

let empresaAtual = null;
const charts = {};

const fmtBRL = (v) => {
  if (v == null || isNaN(v)) return '—';
  return new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL',minimumFractionDigits:2}).format(Number(v));
};
const fmtInt = (v) => {
  if (v == null || isNaN(v)) return '—';
  return new Intl.NumberFormat('pt-BR').format(Number(v));
};
const fmtDate = (s) => {
  if (!s) return '—';
  const d = new Date(s + (s.length === 10 ? 'T00:00:00' : ''));
  return isNaN(d) ? s : d.toLocaleDateString('pt-BR');
};
const fmtMonth = (s) => {
  if (!s) return '—';
  const d = new Date(s + (s.length === 10 ? 'T00:00:00' : ''));
  return d.toLocaleDateString('pt-BR',{month:'short', year:'numeric'});
};

async function fetchJSON(path) {
  const r = await fetch(API_BASE + path);
  if (!r.ok) throw new Error(r.status + ' ' + r.statusText);
  return r.json();
}

function destroyChart(key) {
  if (charts[key]) { charts[key].destroy(); delete charts[key]; }
}

const CHART_DEFAULTS = { color: '#C9B8EA', font: {family: 'Inter', size: 11}, grid: 'rgba(220,200,255,.08)' };
Chart.defaults.color = CHART_DEFAULTS.color;
Chart.defaults.font = CHART_DEFAULTS.font;
Chart.defaults.borderColor = CHART_DEFAULTS.grid;

document.querySelectorAll('.nav-item[data-page]').forEach(el => {
  el.addEventListener('click', () => {
    const page = el.dataset.page;
    document.querySelectorAll('.nav-item[data-page]').forEach(n => n.classList.remove('active'));
    el.classList.add('active');
    document.querySelectorAll('main section').forEach(s => s.classList.add('hidden'));
    document.getElementById('page-'+page).classList.remove('hidden');
    renderPage(page);
  });
});

async function loadEmpresas() {
  try {
    const empresas = await fetchJSON('/bi/empresas');
    const sel = document.getElementById('empresa-select');
    sel.innerHTML = '';
    if (empresas.length === 0) { sel.innerHTML = '<option>Nenhuma empresa cadastrada</option>'; return; }
    empresas.forEach(e => {
      const opt = document.createElement('option');
      opt.value = e.id;
      opt.textContent = e.nome + (e.tem_token ? '' : ' (⚠ sem token)');
      opt.dataset.ultimoSync = e.ultimo_sync_em || '';
      sel.appendChild(opt);
    });
    sel.addEventListener('change', () => selectEmpresa(sel.value));
    selectEmpresa(empresas[0].id);
    document.getElementById('last-sync').textContent =
      empresas[0].ultimo_sync_em ? new Date(empresas[0].ultimo_sync_em).toLocaleString('pt-BR') : 'nunca';
  } catch (e) {
    console.error(e);
    document.getElementById('sync-status').textContent = 'erro ao carregar empresas';
    document.getElementById('sync-status').className = 'sync-status err';
  }
}

function selectEmpresa(id) {
  empresaAtual = id;
  const sel = document.getElementById('empresa-select');
  sel.value = id;
  const ultimoSync = sel.selectedOptions[0]?.dataset.ultimoSync;
  document.getElementById('last-sync').textContent =
    ultimoSync ? new Date(ultimoSync).toLocaleString('pt-BR') : 'nunca';
  const activePage = document.querySelector('.nav-item.active[data-page]').dataset.page;
  renderPage(activePage);
}

document.getElementById('btn-sync').addEventListener('click', async () => {
  if (!empresaAtual) return;
  const btn = document.getElementById('btn-sync');
  const status = document.getElementById('sync-status');
  btn.disabled = true;
  btn.innerHTML = '<span class="loader"></span>  Sincronizando...';
  status.textContent = 'chamando API...';
  status.className = 'sync-status';
  try {
    const r = await fetch(API_BASE + '/sync/' + empresaAtual, {method: 'POST'});
    if (!r.ok) throw new Error(r.statusText);
    status.textContent = 'sync iniciado em background';
    status.className = 'sync-status ok';
    setTimeout(() => {
      const activePage = document.querySelector('.nav-item.active[data-page]').dataset.page;
      renderPage(activePage);
      loadEmpresas();
    }, 5000);
  } catch (e) {
    status.textContent = 'erro: ' + e.message;
    status.className = 'sync-status err';
  }
  btn.disabled = false;
  btn.textContent = 'Sincronizar dados';
});

async function renderPage(page) {
  if (!empresaAtual) return;
  if (page === 'resumo') await renderResumo();
  else if (page === 'fluxo') await renderFluxo();
  else if (page === 'receber') await renderParcelas('RECEBER', 'receber');
  else if (page === 'pagar') await renderParcelas('PAGAR', 'pagar');
  else if (page === 'dre') await renderDRE();
  else if (page === 'vendas') await renderVendas();
}

async function renderResumo() {
  try {
    const [kpis, aging, topCat] = await Promise.all([
      fetchJSON('/bi/' + empresaAtual + '/kpis'),
      fetchJSON('/bi/' + empresaAtual + '/aging'),
      fetchJSON('/bi/' + empresaAtual + '/ranking-categorias?tipo=RECEITA&top=10'),
    ]);
    const cards = [
      {label: 'Total a Receber', value: fmtBRL(kpis.total_a_receber), color: 'blue', sub: fmtInt(kpis.qtd_receber) + ' parcela(s)'},
      {label: 'Total Recebido', value: fmtBRL(kpis.total_recebido), color: 'green', sub: 'realizado'},
      {label: 'Total a Pagar', value: fmtBRL(kpis.total_a_pagar), color: 'red', sub: fmtInt(kpis.qtd_pagar) + ' parcela(s)'},
      {label: 'Total Pago', value: fmtBRL(kpis.total_pago), color: '', sub: 'realizado'},
      {label: 'Receber Vencido', value: fmtBRL(kpis.receber_vencido), color: 'gold', sub: 'em atraso'},
      {label: 'Saldo Projetado', value: fmtBRL(kpis.saldo_projetado), color: kpis.saldo_projetado >= 0 ? 'green' : 'red', sub: 'líquido a realizar'},
    ];
    document.getElementById('kpi-cards').innerHTML = cards.map(c =>
      '<div class="kpi ' + (c.color||'') + '"><div class="kpi-label">' + c.label + '</div><div class="kpi-value">' + c.value + '</div><div class="kpi-sub">' + c.sub + '</div></div>'
    ).join('');

    const agR = aging.filter(a => a.tipo === 'RECEBER');
    destroyChart('agR');
    charts.agR = new Chart(document.getElementById('ch-aging-receber'), {
      type: 'bar',
      data: { labels: agR.map(a => a.faixa),
        datasets: [{ label: 'Saldo aberto (R$)', data: agR.map(a => a.saldo_aberto),
          backgroundColor: ['#10B981','#F59E0B','#F97316','#EF4444','#991B1B'], borderRadius: 6 }] },
      options: { maintainAspectRatio: false, plugins: {legend: {display: false}},
        scales: { y: {ticks: {callback: v => fmtBRL(v)}, grid: {color: CHART_DEFAULTS.grid}},
                  x: {grid: {display: false}} } }
    });

    const agP = aging.filter(a => a.tipo === 'PAGAR');
    destroyChart('agP');
    charts.agP = new Chart(document.getElementById('ch-aging-pagar'), {
      type: 'bar',
      data: { labels: agP.length ? agP.map(a => a.faixa) : ['Sem dados'],
        datasets: [{ label: 'Saldo aberto (R$)', data: agP.length ? agP.map(a => a.saldo_aberto) : [0],
          backgroundColor: ['#3B82F6','#8B5CF6','#A855F7','#EC2E9A','#831843'], borderRadius: 6 }] },
      options: { maintainAspectRatio: false, plugins: {legend: {display: false}},
        scales: { y: {ticks: {callback: v => fmtBRL(v)}, grid: {color: CHART_DEFAULTS.grid}},
                  x: {grid: {display: false}} } }
    });

    destroyChart('topCat');
    charts.topCat = new Chart(document.getElementById('ch-top-categorias'), {
      type: 'bar',
      data: { labels: topCat.map(c => c.categoria),
        datasets: [ {label: 'Realizado', data: topCat.map(c => c.realizado), backgroundColor: '#10B981', borderRadius: 5},
                    {label: 'Previsto',  data: topCat.map(c => c.previsto),  backgroundColor: '#9333EA', borderRadius: 5} ] },
      options: { maintainAspectRatio: false, indexAxis: 'y', plugins: {legend: {position: 'top'}},
        scales: { x: {ticks: {callback: v => fmtBRL(v)}, grid: {color: CHART_DEFAULTS.grid}},
                  y: {grid: {display: false}} } }
    });
  } catch (e) {
    console.error(e);
    document.getElementById('kpi-cards').innerHTML =
      '<div class="panel"><div class="empty-state"><h4>Erro carregando dados</h4><div>' + e.message + '</div></div></div>';
  }
}

async function renderFluxo() {
  try {
    const dados = await fetchJSON('/bi/' + empresaAtual + '/fluxo-caixa');
    if (dados.length === 0) {
      document.querySelector('#page-fluxo .chart-wrap').innerHTML = '<div class="empty-state"><h4>Sem dados</h4></div>';
      return;
    }
    const labels = dados.map(d => fmtDate(d.data));
    destroyChart('fluxo');
    charts.fluxo = new Chart(document.getElementById('ch-fluxo'), {
      type: 'line',
      data: { labels,
        datasets: [
          {label: 'Entrada Realizada', data: dados.map(d=>d.entrada_realizada), borderColor: '#10B981', tension: .3, fill: false},
          {label: 'Saída Realizada', data: dados.map(d=>d.saida_realizada), borderColor: '#EF4444', tension: .3, fill: false},
          {label: 'Entrada Prevista', data: dados.map(d=>d.entrada_prevista), borderColor: '#22D3EE', borderDash: [5,5], tension: .3, fill: false},
          {label: 'Saída Prevista',   data: dados.map(d=>d.saida_prevista),   borderColor: '#F59E0B', borderDash: [5,5], tension: .3, fill: false},
        ] },
      options: { maintainAspectRatio: false, plugins: {legend: {position: 'top'}},
        scales: { y: {ticks: {callback: v => fmtBRL(v)}, grid: {color: CHART_DEFAULTS.grid}},
                  x: {grid: {display: false}} } }
    });

    let saldo = 0;
    const saldoData = dados.map(d => { saldo += (d.entrada_realizada - d.saida_realizada); return saldo; });
    destroyChart('saldo');
    charts.saldo = new Chart(document.getElementById('ch-saldo-acum'), {
      type: 'line',
      data: {labels, datasets: [{label: 'Saldo acumulado', data: saldoData,
        borderColor: '#A855F7', backgroundColor: 'rgba(168,85,247,.15)', tension: .3, fill: true }]},
      options: { maintainAspectRatio: false, plugins: {legend: {display: false}},
        scales: { y: {ticks: {callback: v => fmtBRL(v)}, grid: {color: CHART_DEFAULTS.grid}},
                  x: {grid: {display: false}} } }
    });

    const totais = dados.reduce((acc, d) => {
      acc.entRea += d.entrada_realizada; acc.entPre += d.entrada_prevista;
      acc.saiRea += d.saida_realizada;   acc.saiPre += d.saida_prevista;
      return acc;
    }, {entRea:0, entPre:0, saiRea:0, saiPre:0});
    document.querySelector('#tbl-fluxo-totais tbody').innerHTML =
      '<tr><td>Total Entrada Realizada</td><td class="num">' + fmtBRL(totais.entRea) + '</td></tr>' +
      '<tr><td>Total Saída Realizada</td><td class="num">' + fmtBRL(totais.saiRea) + '</td></tr>' +
      '<tr><td>Total Entrada Prevista</td><td class="num">' + fmtBRL(totais.entPre) + '</td></tr>' +
      '<tr><td>Total Saída Prevista</td><td class="num">' + fmtBRL(totais.saiPre) + '</td></tr>' +
      '<tr><td><strong>Saldo Realizado</strong></td><td class="num"><strong>' + fmtBRL(totais.entRea - totais.saiRea) + '</strong></td></tr>' +
      '<tr><td><strong>Saldo Previsto</strong></td><td class="num"><strong>' + fmtBRL(totais.entPre - totais.saiPre) + '</strong></td></tr>';
  } catch (e) { console.error(e); }
}

async function renderParcelas(tipo, pageId) {
  try {
    const parc = await fetchJSON('/bi/' + empresaAtual + '/parcelas?limite=500');
    const filtradas = parc.filter(p => p.tipo === tipo);
    const tbody = document.querySelector('#tbl-' + pageId + ' tbody');
    tbody.innerHTML = filtradas.map(p => {
      const situ = p.situacao_calculada || '—';
      const pillClass = situ === 'LIQUIDADO' ? 'liq' :
                        situ === 'VENCIDO' ? 'vencido' :
                        situ.indexOf('VENCER') >= 0 ? 'avencer' : 'aberto';
      return '<tr>' +
        '<td>' + (p.pessoa_nome || '—') + '</td>' +
        '<td>' + (p.descricao || '—') + '</td>' +
        '<td>' + fmtDate(p.data_vencimento) + '</td>' +
        '<td>' + fmtDate(p.data_pagamento) + '</td>' +
        '<td class="num">' + fmtBRL(p.valor_previsto) + '</td>' +
        '<td class="num">' + fmtBRL(p.valor_pago) + '</td>' +
        '<td class="num">' + fmtBRL(p.saldo_aberto) + '</td>' +
        '<td><span class="pill ' + pillClass + '">' + situ + '</span></td>' +
        '<td class="num">' + (p.dias_atraso > 0 ? p.dias_atraso : '—') + '</td>' +
        '</tr>';
    }).join('');
    const total = filtradas.reduce((s,p) => s + p.valor_previsto, 0);
    const totalAberto = filtradas.reduce((s,p) => s + p.saldo_aberto, 0);
    document.getElementById('sub-' + pageId).textContent =
      filtradas.length + ' parcela(s) • Total previsto: ' + fmtBRL(total) + ' • Saldo aberto: ' + fmtBRL(totalAberto);
  } catch (e) { console.error(e); }
}

async function renderDRE() {
  try {
    const [rec, desp, dre] = await Promise.all([
      fetchJSON('/bi/' + empresaAtual + '/ranking-categorias?tipo=RECEITA&top=10'),
      fetchJSON('/bi/' + empresaAtual + '/ranking-categorias?tipo=DESPESA&top=10'),
      fetchJSON('/bi/' + empresaAtual + '/dre'),
    ]);
    destroyChart('dreRec');
    charts.dreRec = new Chart(document.getElementById('ch-dre-receitas'), {
      type: 'bar',
      data: { labels: rec.map(r => r.categoria),
        datasets: [ {label: 'Realizado', data: rec.map(r=>r.realizado), backgroundColor: '#10B981', borderRadius: 5},
                    {label: 'Previsto',  data: rec.map(r=>r.previsto),  backgroundColor: '#22D3EE', borderRadius: 5} ] },
      options: { maintainAspectRatio: false, indexAxis: 'y', plugins: {legend: {position: 'top'}},
        scales: {x: {ticks: {callback: v => fmtBRL(v)}, grid: {color: CHART_DEFAULTS.grid}}, y: {grid: {display: false}}} }
    });
    destroyChart('dreDesp');
    charts.dreDesp = new Chart(document.getElementById('ch-dre-despesas'), {
      type: 'bar',
      data: { labels: desp.length ? desp.map(r => r.categoria) : ['Sem dados'],
        datasets: [ {label: 'Realizado', data: desp.length ? desp.map(r=>r.realizado) : [0], backgroundColor: '#EF4444', borderRadius: 5},
                    {label: 'Previsto',  data: desp.length ? desp.map(r=>r.previsto)  : [0], backgroundColor: '#F59E0B', borderRadius: 5} ] },
      options: { maintainAspectRatio: false, indexAxis: 'y', plugins: {legend: {position: 'top'}},
        scales: {x: {ticks: {callback: v => fmtBRL(v)}, grid: {color: CHART_DEFAULTS.grid}}, y: {grid: {display: false}}} }
    });
    const tbody = document.querySelector('#tbl-dre tbody');
    tbody.innerHTML = dre.map(r =>
      '<tr>' +
      '<td>' + fmtMonth(r.mes) + '</td>' +
      '<td><span class="pill ' + (r.tipo_categoria === 'RECEITA' ? 'rec' : 'pag') + '">' + (r.tipo_categoria || '—') + '</span></td>' +
      '<td>' + (r.categoria || '(sem categoria)') + '</td>' +
      '<td class="num">' + fmtBRL(r.valor_previsto) + '</td>' +
      '<td class="num">' + fmtBRL(r.valor_realizado) + '</td>' +
      '<td class="num">' + fmtInt(r.qtd_lancamentos) + '</td>' +
      '</tr>'
    ).join('');
  } catch (e) { console.error(e); }
}

async function renderVendas() {
  try {
    const vendas = await fetchJSON('/bi/' + empresaAtual + '/vendas');
    const total = vendas.reduce((s,v) => s + v.valor_total, 0);
    const ticket = vendas.length ? total / vendas.length : 0;
    const aprovadas = vendas.filter(v => (v.status||'').toUpperCase() === 'APROVADO').length;
    document.getElementById('kpi-vendas').innerHTML =
      '<div class="kpi blue"><div class="kpi-label">Total de Vendas</div><div class="kpi-value">' + fmtInt(vendas.length) + '</div><div class="kpi-sub">transações</div></div>' +
      '<div class="kpi green"><div class="kpi-label">Receita Bruta</div><div class="kpi-value">' + fmtBRL(total) + '</div><div class="kpi-sub">somatório</div></div>' +
      '<div class="kpi gold"><div class="kpi-label">Ticket Médio</div><div class="kpi-value">' + fmtBRL(ticket) + '</div><div class="kpi-sub">por venda</div></div>' +
      '<div class="kpi"><div class="kpi-label">Aprovadas</div><div class="kpi-value">' + fmtInt(aprovadas) + '</div><div class="kpi-sub">de ' + fmtInt(vendas.length) + '</div></div>';
    const tbody = document.querySelector('#tbl-vendas tbody');
    tbody.innerHTML = vendas.map(v =>
      '<tr>' +
      '<td>' + (v.numero != null ? v.numero : '—') + '</td>' +
      '<td>' + fmtDate(v.data_venda) + '</td>' +
      '<td>' + (v.cliente_nome || '—') + '</td>' +
      '<td class="num">' + fmtBRL(v.valor_total) + '</td>' +
      '<td><span class="pill ' + ((v.status||'').toUpperCase() === 'APROVADO' ? 'rec' : 'aberto') + '">' + (v.status || '—') + '</span></td>' +
      '<td>' + (v.descricao || '—') + '</td>' +
      '</tr>'
    ).join('');
  } catch (e) { console.error(e); }
}

loadEmpresas();
</script>
