# =============================================================================
# bi_conta_azul — configuração
# Copie para ".env" e preencha. NUNCA commitar .env no git.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bi_conta_azul
DB_USER=postgres
DB_PASSWORD=postgres

# --- Criptografia (pgcrypto) --------------------------------------------------
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
CRYPTO_MASTER_KEY=trocar-em-producao-por-chave-forte-minimo-32-bytes

# --- App ContaAzul (Portal Dev — criado pela PED Intelligence) ---------------
# Portal: https://portaldev.contaazul.com
CA_CLIENT_ID=seu-client-id-aqui
CA_CLIENT_SECRET=seu-client-secret-aqui
CA_REDIRECT_URI=http://localhost:8000/auth/callback

# Endpoints da API v2 (não alterar, a menos que a ContaAzul atualize)
CA_AUTH_BASE=https://auth.contaazul.com
CA_API_BASE=https://api-v2.contaazul.com/v1

# --- API local ----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
